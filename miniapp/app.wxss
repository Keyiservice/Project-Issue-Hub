page {
  min-height: 100%;
  background:
    radial-gradient(circle at 12% 0%, rgba(206, 128, 61, 0.18) 0%, rgba(206, 128, 61, 0) 28%),
    radial-gradient(circle at 88% 10%, rgba(48, 93, 134, 0.14) 0%, rgba(48, 93, 134, 0) 26%),
    linear-gradient(145deg, #efe7db 0%, #faf7f1 52%, #ebf2ef 100%),
    linear-gradient(rgba(32, 47, 60, 0.045) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(32, 47, 60, 0.045) 1rpx, transparent 1rpx);
  background-size: auto, auto, auto, 32rpx 32rpx, 32rpx 32rpx;
  color: #17212b;
  font-size: 28rpx;
}

.page-shell {
  position: relative;
  min-height: 100vh;
  padding: 24rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.safe-bottom {
  padding-bottom: 40rpx;
}

.ambient-rig {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  height: 420rpx;
  pointer-events: none;
  overflow: hidden;
}

.ambient-grid {
  position: absolute;
  inset: 0;
  opacity: 0.58;
  background-image:
    linear-gradient(rgba(39, 54, 67, 0.07) 1rpx, transparent 1rpx),
    linear-gradient(90deg, rgba(39, 54, 67, 0.07) 1rpx, transparent 1rpx);
  background-size: 40rpx 40rpx;
}

.ambient-glow {
  position: absolute;
  width: 260rpx;
  height: 260rpx;
  border-radius: 50%;
  filter: blur(4rpx);
}

.ambient-glow-left {
  left: -36rpx;
  top: -48rpx;
  background: radial-gradient(circle, rgba(210, 119, 42, 0.22) 0%, rgba(210, 119, 42, 0) 72%);
}

.ambient-glow-right {
  right: -30rpx;
  top: 36rpx;
  background: radial-gradient(circle, rgba(47, 103, 149, 0.18) 0%, rgba(47, 103, 149, 0) 72%);
}

.ambient-line {
  position: absolute;
  left: 28rpx;
  right: 28rpx;
  height: 8rpx;
  border-radius: 999rpx;
  background: linear-gradient(90deg, rgba(214, 131, 58, 0), rgba(214, 131, 58, 0.72), rgba(214, 131, 58, 0));
  opacity: 0.8;
}

.ambient-line-top {
  top: 72rpx;
}

.ambient-line-bottom {
  top: 150rpx;
  background: linear-gradient(90deg, rgba(67, 118, 161, 0), rgba(67, 118, 161, 0.66), rgba(67, 118, 161, 0));
}

.glass-card {
  margin-bottom: 20rpx;
  padding: 28rpx;
  border-radius: 24rpx;
  position: relative;
  z-index: 1;
  background:
    linear-gradient(145deg, rgba(255, 252, 247, 0.98) 0%, rgba(248, 244, 237, 0.95) 58%, rgba(243, 248, 245, 0.95) 100%),
    linear-gradient(90deg, rgba(36, 53, 68, 0.04), rgba(36, 53, 68, 0) 42%);
  border: 1rpx solid rgba(23, 33, 43, 0.085);
  box-shadow: 0 14rpx 34rpx rgba(58, 56, 42, 0.09), inset 0 1rpx 0 rgba(255, 255, 255, 0.72);
}

.command-card {
  background:
    linear-gradient(145deg, rgba(255, 249, 242, 0.98) 0%, rgba(248, 244, 237, 0.95) 52%, rgba(238, 247, 244, 0.95) 100%),
    linear-gradient(90deg, rgba(30, 47, 60, 0.075) 0, rgba(30, 47, 60, 0) 38%);
  border-color: rgba(23, 33, 43, 0.1);
}

.section-kicker {
  margin-bottom: 10rpx;
  font-size: 20rpx;
  letter-spacing: 0.2em;
  text-transform: uppercase;
  color: #8b99a7;
}

.section-title {
  margin: 0;
  font-size: 44rpx;
  line-height: 1.15;
  font-weight: 700;
  color: #17212b;
}

.section-desc {
  margin-top: 14rpx;
  color: #647382;
  line-height: 1.7;
}

.metric-grid,
.action-grid,
.media-grid,
.timeline {
  margin-top: 16rpx;
}

.metric-card,
.action-card,
.media-card,
.timeline-item {
  margin-top: 16rpx;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(23, 33, 43, 0.06);
}

.metric-card:first-child,
.action-card:first-child,
.media-card:first-child,
.timeline-item:first-child {
  margin-top: 0;
}

.metric-label {
  font-size: 22rpx;
  color: #7d8a97;
}

.metric-value {
  margin-top: 10rpx;
  font-size: 40rpx;
  line-height: 1.1;
  font-weight: 700;
  color: #17212b;
}

.metric-note {
  margin-top: 8rpx;
  color: #8b99a7;
  font-size: 22rpx;
}

.action-card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #17212b;
}

.action-card-desc {
  margin-top: 8rpx;
  color: #647382;
  line-height: 1.6;
}

.primary-btn,
.secondary-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  margin-top: 16rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.mini-switch-btn {
  min-width: 180rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(23, 33, 43, 0.08);
  color: #17212b;
  font-size: 24rpx;
  font-weight: 600;
}

.mini-switch-btn::after {
  border: none;
}

.primary-btn {
  background: linear-gradient(135deg, #cb5d1f 0%, #e07e35 100%);
  color: #ffffff;
  border: none;
}

.secondary-btn {
  background: rgba(255, 255, 255, 0.92);
  color: #17212b;
  border: 1rpx solid rgba(23, 33, 43, 0.08);
}

.primary-btn::after,
.secondary-btn::after {
  border: none;
}

.field-block {
  margin-bottom: 22rpx;
}

.field-label {
  display: block;
  margin-bottom: 12rpx;
  color: #506071;
  font-size: 24rpx;
  font-weight: 600;
}

.field-input,
.field-textarea,
.picker-field {
  width: 100%;
  min-height: 92rpx;
  padding: 24rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(23, 33, 43, 0.08);
  box-sizing: border-box;
  color: #17212b;
}

.field-textarea {
  min-height: 220rpx;
}

.picker-placeholder {
  color: #9aa6b2;
}

.chip-row,
.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 64rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(100, 115, 130, 0.12);
  color: #556575;
  font-size: 24rpx;
  font-weight: 600;
  border: 1rpx solid rgba(100, 115, 130, 0.12);
}

.chip.active {
  background: rgba(203, 93, 31, 0.12);
  color: #a34612;
  border-color: rgba(203, 93, 31, 0.18);
}

.media-type {
  font-size: 20rpx;
  letter-spacing: 0.16em;
  text-transform: uppercase;
  color: #8b99a7;
}

.media-name {
  margin-top: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
  color: #17212b;
  word-break: break-all;
}

.media-meta {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #647382;
}

.tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 54rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.tag.orange {
  color: #a34612;
  background: rgba(203, 93, 31, 0.12);
}

.tag.blue {
  color: #164a84;
  background: rgba(35, 95, 167, 0.12);
}

.tag.teal {
  color: #0b5b55;
  background: rgba(15, 118, 110, 0.12);
}

.tag.amber {
  color: #825113;
  background: rgba(183, 114, 29, 0.12);
}

.tag.rose {
  color: #9f4135;
  background: rgba(198, 92, 78, 0.12);
}

.tag.gray {
  color: #556575;
  background: rgba(100, 115, 130, 0.12);
}

.timeline-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.timeline-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #17212b;
}

.timeline-time {
  color: #8b99a7;
  font-size: 22rpx;
}

.timeline-content {
  margin-top: 12rpx;
  color: #647382;
  line-height: 1.7;
  white-space: pre-wrap;
}

.empty-card {
  position: relative;
  z-index: 1;
  padding: 40rpx 24rpx;
  border-radius: 24rpx;
  background: rgba(255, 255, 255, 0.8);
  text-align: center;
  color: #647382;
}
