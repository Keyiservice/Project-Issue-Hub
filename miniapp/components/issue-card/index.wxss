.issue-card {
  padding: 24rpx;
  border-radius: 26rpx;
  background: rgba(255, 252, 247, 0.82);
  border: 1rpx solid rgba(23, 33, 43, 0.08);
  box-shadow: 0 14rpx 36rpx rgba(84, 67, 38, 0.08);
}

.issue-card + .issue-card {
  margin-top: 16rpx;
}

.issue-card-head,
.issue-foot {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.issue-no {
  font-size: 20rpx;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #8b99a7;
}

.issue-title {
  margin-top: 14rpx;
  font-size: 30rpx;
  line-height: 1.5;
  font-weight: 700;
  color: #17212b;
}

.issue-line {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 12rpx;
  color: #647382;
  font-size: 24rpx;
}

.issue-foot {
  margin-top: 16rpx;
  color: #647382;
  font-size: 24rpx;
}

.issue-overdue {
  color: #c65c4e;
  font-weight: 700;
}

.mini-tag {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-height: 48rpx;
  padding: 0 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.tone-orange {
  color: #a34612;
  background: rgba(203, 93, 31, 0.12);
}

.tone-blue {
  color: #164a84;
  background: rgba(35, 95, 167, 0.12);
}

.tone-teal {
  color: #0b5b55;
  background: rgba(15, 118, 110, 0.12);
}

.tone-amber {
  color: #825113;
  background: rgba(183, 114, 29, 0.12);
}

.tone-rose {
  color: #9f4135;
  background: rgba(198, 92, 78, 0.12);
}

.tone-gray {
  color: #556575;
  background: rgba(100, 115, 130, 0.12);
}
