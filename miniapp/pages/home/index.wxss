.home-top-card,
.quick-section,
.stats-section {
  margin-top: 20rpx;
}

.home-top-card {
  margin-top: 0;
}

.home-top-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.home-title {
  margin-top: 4rpx;
  font-size: 42rpx;
}

.home-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 18rpx;
}

.home-chip {
  display: inline-flex;
  align-items: center;
  min-height: 54rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(23, 33, 43, 0.06);
  color: #647382;
  font-size: 22rpx;
  font-weight: 600;
  box-sizing: border-box;
}

.home-entry-grid,
.compact-stat-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: 20rpx;
}

.home-entry-card,
.compact-stat-card {
  width: 48.5%;
  box-sizing: border-box;
}

.home-entry-card {
  min-height: 168rpx;
  padding: 22rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.84);
  border: 1rpx solid rgba(23, 33, 43, 0.08);
}

.entry-strong {
  background: linear-gradient(145deg, rgba(203, 93, 31, 0.16), rgba(255, 255, 255, 0.94));
}

.entry-mark,
.quick-mark {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 76rpx;
  height: 54rpx;
  padding: 0 14rpx;
  border-radius: 16rpx;
  background: #243544;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0.1em;
  box-sizing: border-box;
}

.entry-name,
.quick-name {
  margin-top: 18rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #17212b;
}

.quick-grid {
  display: flex;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: 18rpx;
}

.quick-card {
  flex: 1;
  min-height: 150rpx;
  padding: 20rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(23, 33, 43, 0.08);
  box-sizing: border-box;
}

.compact-stat-card {
  min-height: 136rpx;
  margin-top: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
}
