.detail-title {
  font-size: 40rpx;
}

.back-project-btn {
  margin-top: 20rpx;
}

.detail-tags,
.close-form,
.rule-row {
  margin-top: 18rpx;
}

.hero-attachment-strip {
  display: flex;
  overflow-x: auto;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-bottom: 6rpx;
}

.hero-attachment-card {
  width: 250rpx;
  flex-shrink: 0;
  overflow: hidden;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.84);
  border: 1rpx solid rgba(23, 33, 43, 0.08);
}

.hero-attachment-thumb,
.hero-video-thumb,
.comment-attachment-thumb,
.comment-video-thumb {
  width: 250rpx;
  height: 164rpx;
}

.hero-video-wrap,
.comment-video-thumb {
  position: relative;
}

.video-cover {
  width: 100%;
  height: 100%;
}

.hero-video-thumb,
.comment-video-thumb {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(145deg, #243544 0%, #1f2c39 50%, #304355 100%);
  color: #ffffff;
}

.hero-video-mask {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(15, 20, 24, 0.18);
}

.hero-video-play {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 0.14em;
}

.hero-video-label {
  margin-top: 14rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.76);
}

.hero-attachment-meta {
  padding: 16rpx 18rpx 18rpx;
}

.hero-attachment-name {
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.5;
  color: #17212b;
  word-break: break-all;
}

.hero-attachment-extra {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #8b99a7;
}

.draft-remove {
  margin-top: 10rpx;
  color: #cb5d1f;
  font-size: 22rpx;
  font-weight: 700;
}

.detail-meta-card,
.action-card,
.comment-submit {
  margin-top: 20rpx;
}

.meta-grid,
.evidence-block {
  margin-top: 16rpx;
}

.meta-value {
  margin-top: 10rpx;
  font-size: 30rpx;
  line-height: 1.5;
  font-weight: 700;
  color: #17212b;
}

.short-textarea {
  min-height: 150rpx;
}

.comment-upload-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 18rpx;
}

.half-btn {
  flex: 1;
}

.comment-attachment-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: 16rpx;
}

.comment-attachment-card {
  width: 48.5%;
  overflow: hidden;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.84);
  border: 1rpx solid rgba(23, 33, 43, 0.08);
  box-sizing: border-box;
}

.comment-attachment-name {
  padding: 12rpx 14rpx 14rpx;
  font-size: 22rpx;
  color: #17212b;
  line-height: 1.45;
  word-break: break-all;
}

.preview-layer {
  position: fixed;
  inset: 0;
  z-index: 99;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx;
  background: rgba(13, 18, 24, 0.72);
  box-sizing: border-box;
}

.preview-shell {
  width: 100%;
  max-height: 88vh;
  padding: 20rpx;
  border-radius: 24rpx;
  background: rgba(16, 24, 32, 0.96);
  box-sizing: border-box;
}

.preview-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.preview-title {
  flex: 1;
  color: #f8fbfe;
  font-size: 26rpx;
  font-weight: 700;
  word-break: break-all;
}

.preview-close {
  color: #cfd8df;
  font-size: 24rpx;
}

.preview-image,
.preview-video {
  width: 100%;
  height: 72vh;
  border-radius: 18rpx;
  background: #0f1418;
}
