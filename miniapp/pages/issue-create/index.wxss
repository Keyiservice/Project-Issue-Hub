.form-card,
.upload-card {
  margin-top: 20rpx;
}

.report-grid {
  margin-top: 20rpx;
}

.report-item {
  margin-top: 14rpx;
  padding: 20rpx 22rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(23, 33, 43, 0.06);
}

.report-item:first-child {
  margin-top: 0;
}

.report-value {
  margin-top: 8rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #17212b;
}

.switch-grid {
  margin-top: 6rpx;
}

.switch-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(23, 33, 43, 0.06);
}

.switch-card + .switch-card {
  margin-top: 16rpx;
}

.switch-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #17212b;
}

.upload-title {
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #17212b;
}

.rule-row {
  margin-top: 18rpx;
}

.upload-actions {
  margin-top: 18rpx;
}

.media-top {
  display: flex;
  justify-content: space-between;
  gap: 16rpx;
}

.remove-link {
  color: #a34612;
  font-size: 24rpx;
  font-weight: 600;
}
