.search-block {
  margin-top: 20rpx;
}

.project-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  margin-top: 20rpx;
  margin-bottom: 20rpx;
  padding: 22rpx 24rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.72);
  border: 1rpx solid rgba(23, 33, 43, 0.06);
}

.project-name {
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #17212b;
}

.mini-switch-btn {
  min-width: 180rpx;
  height: 72rpx;
  line-height: 72rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(23, 33, 43, 0.08);
  color: #17212b;
  font-size: 24rpx;
  font-weight: 600;
}

.owner-filter {
  margin-bottom: 18rpx;
}

.picker-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-height: 88rpx;
  padding: 0 26rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.78);
  border: 1rpx solid rgba(23, 33, 43, 0.08);
}

.picker-text {
  flex: 1;
  font-size: 26rpx;
  color: #17212b;
  font-weight: 600;
}

.picker-arrow {
  font-size: 22rpx;
  color: #7f8da0;
}

.search-button {
  margin-bottom: 18rpx;
}

.metric-grid-quad {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 14rpx;
}

.metric-grid-quad .metric-card {
  width: 48.5%;
  min-height: 144rpx;
  margin-top: 0;
  box-sizing: border-box;
}

.metric-grid-quad .metric-note {
  line-height: 1.5;
}

.issue-list {
  margin-top: 20rpx;
}
