.compact-hero {
  padding-bottom: 20rpx;
}

.compact-head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.compact-head .section-desc {
  margin-top: 10rpx;
  max-width: 420rpx;
}

.compact-metric-grid,
.compact-action-grid,
.compact-strip {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  gap: 14rpx;
}

.compact-metric-grid {
  margin-top: 18rpx;
}

.compact-metric-card,
.compact-action-card,
.strip-item {
  width: 48.5%;
  box-sizing: border-box;
}

.compact-metric-card {
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(23, 33, 43, 0.06);
}

.sub-title {
  margin-top: 6rpx;
  font-size: 36rpx;
}

.compact-action-grid {
  margin-top: 18rpx;
}

.compact-action-card {
  min-height: 156rpx;
  padding: 18rpx;
  border-radius: 22rpx;
  border: 1rpx solid rgba(23, 33, 43, 0.06);
}

.accent-orange {
  background: linear-gradient(145deg, rgba(203, 93, 31, 0.14), rgba(255, 255, 255, 0.9));
}

.accent-slate {
  background: linear-gradient(145deg, rgba(36, 53, 68, 0.12), rgba(255, 255, 255, 0.9));
}

.accent-teal {
  background: linear-gradient(145deg, rgba(15, 118, 110, 0.12), rgba(255, 255, 255, 0.9));
}

.accent-blue {
  background: linear-gradient(145deg, rgba(35, 95, 167, 0.12), rgba(255, 255, 255, 0.9));
}

.action-card-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 76rpx;
  height: 56rpx;
  padding: 0 14rpx;
  border-radius: 16rpx;
  background: #243544;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 0.12em;
}

.action-card-name {
  margin-top: 12rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: #17212b;
}

.action-card-note {
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.45;
  color: #647382;
}

.compact-strip {
  margin-top: 14rpx;
}

.strip-item {
  padding: 16rpx 18rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.82);
  border: 1rpx solid rgba(23, 33, 43, 0.06);
}

.strip-value {
  margin-top: 10rpx;
  font-size: 34rpx;
  font-weight: 700;
  color: #17212b;
}

.compact-focus-item {
  margin-top: 14rpx;
}

.compact-focus-body {
  padding-top: 18rpx;
  padding-bottom: 18rpx;
}

.compact-focus-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx 18rpx;
  margin-top: 12rpx;
  color: #647382;
  font-size: 24rpx;
}
